{
  "name": "stitch-bridge",
  "version": "0.1.0",
  "description": "MCP server bridging AI coding agents to Google Stitch design platform",
  "type": "module",
  "bin": {
    "stitch-bridge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "stitch",
    "google-stitch",
    "design",
    "ui",
    "ai-design",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/stitch-sdk": "^0.0.3",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
